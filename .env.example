# ── Security ──────────────────────────────────────────────────────────────────
# Required. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Never reuse across environments; rotate if leaked.
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# ── Database ──────────────────────────────────────────────────────────────────
# SQLAlchemy URL. Relative path is fine for local dev; use absolute in production
# so the path is stable regardless of working directory.
#   Local dev:   sqlite:///./data/projectreef.db
#   Production:  sqlite:////opt/projectreef/data/projectreef.db
DATABASE_URL=sqlite:///./data/projectreef.db

# ── Home Assistant (optional) ─────────────────────────────────────────────────
# Leave blank to disable push reminders. The scheduler still runs but skips
# silently when HA_URL / HA_TOKEN are empty.
#
# HA_URL:   Base URL of your Home Assistant instance (no trailing slash).
# HA_TOKEN: Long-lived access token from HA → Profile → Long-Lived Access Tokens.
#
# The per-user notify service (e.g. notify.mobile_app_yourphone) is configured
# inside the app under Profile → Notification Service — it is not an env var.
HA_URL=http://192.168.1.x:8123
HA_TOKEN=

# APP_URL: Public base URL of THIS ProjectReef instance (no trailing slash).
# When set, tapping an HA reminder notification opens that task in ProjectReef
# instead of Home Assistant. Also configurable at runtime under
# Admin → Home Assistant → App URL (takes precedence over this env var).
#   Examples:
#     http://192.168.1.50:8000
#     https://reef.your-tailnet.ts.net
APP_URL=

# ── Server ────────────────────────────────────────────────────────────────────
# Port uvicorn listens on (used when running via `python main.py`).
# When deployed with systemd the ExecStart line hard-codes this too.
PORT=8000

# Comma-separated list of allowed CORS origins.
# Always include the LXC IP + port. Add your Tailscale hostname for remote access.
#   Examples:
#     http://192.168.1.50:8000
#     https://reef.your-tailnet.ts.net
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── API docs ──────────────────────────────────────────────────────────────────
# Swagger UI (/docs) and ReDoc (/redoc) are disabled by default in production.
# Set to true only in development or when you need to explore the API.
ENABLE_DOCS=false
